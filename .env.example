# OpenAI-compatible model endpoint
OPENAI_API_KEY=
OPENAI_BASE_URL=
MODEL_NAME=
OPENAI_MODEL=

# Embedding and retrieval
EMBEDDING_MODEL=
ALLOW_HASH_EMBEDDING_FALLBACK=true
RERANKER_MODEL=
ENABLE_CROSS_ENCODER_RERANKER=false

# Local output and workspace paths
DEFAULT_OUTPUT_DIR=data/outputs
OUTPUT_DIR=data/outputs
UPLOAD_DIR=data/uploads
VECTORSTORE_DIR=data/vectorstores
WORKSPACE_DIR=data/workspaces

# Runtime settings
REQUEST_TIMEOUT_SECONDS=60
MAX_PAPER_CHUNK_TOKENS=220
CHUNK_OVERLAP_TOKENS=40
TOP_K_RETRIEVAL=8
RERANKER_CANDIDATE_MULTIPLIER=4
GIT_CLONE_TIMEOUT_SECONDS=120
MAX_ZIP_MEMBERS=4000
MAX_ZIP_TOTAL_BYTES=150000000
